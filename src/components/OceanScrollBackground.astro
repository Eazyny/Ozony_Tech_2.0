  section {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    padding: clamp(6rem, 10vw, 10rem) clamp(1.25rem, 6vw, 6rem);
  }

  .section-shell,
  .hero-grid {
    width: min(118rem, 100%);
    margin-inline: auto;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(22rem, 32rem);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }

  .hero-copy {
    max-width: 78rem;
  }

  .tag {
    font-size: clamp(0.58rem, 0.78vw, 0.72rem);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-block-end: 1.1rem;
    opacity: 0;
    translate: 0 var(--reveal-offset);
    transition:
      opacity var(--reveal-duration) ease,
      translate var(--reveal-duration) ease;
