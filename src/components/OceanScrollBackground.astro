---
const penUrl = "https://codepen.io/luis-lessrain/full/LERxVqv";
---

<div class="codepen-background-shell">
  <iframe
    class="codepen-background-frame"
    src={penUrl}
    title="WebGL Scroll Sync V3 by LESS RAIN"
    loading="eager"
    allow="fullscreen"
  ></iframe>
</div>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    overflow: hidden;
    background: #0a0a0f;
  }

  .codepen-background-shell {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #0a0a0f;
  }

  .codepen-background-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    background: #0a0a0f;
  }
</style>