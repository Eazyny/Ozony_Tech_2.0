<div id="contact-intake" class="contact-intake-section">
  <div class="contact-intake-shell">
    <div class="contact-intake-heading">
      <div class="contact-intake-tag">Start a project</div>

      <h2>
        Tell us what your business needs help with.
      </h2>

      <p>
        Use the form below for network setup, business Wi-Fi, firewall cleanup,
        website work, IT support, or a full technology cleanup. Your message
        goes directly to Ozony Tech without opening an email app.
      </p>
    </div>

    <form
      class="contact-form"
      data-ozony-contact-form
      action="https://formspree.io/f/mdawpzqp"
      method="POST"
    >
      <input type="hidden" name="_subject" value="New Ozony Tech website inquiry" />

      <label class="contact-field">
        <span>Name</span>
        <input type="text" name="name" autocomplete="name" required />
      </label>

      <label class="contact-field">
        <span>Email</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>

      <label class="contact-field">
        <span>Phone</span>
        <input type="tel" name="phone" autocomplete="tel" />
      </label>

      <label class="contact-field">
        <span>Business name</span>
        <input type="text" name="business_name" autocomplete="organization" />
      </label>

      <label class="contact-field contact-field-wide">
        <span>What do you need help with?</span>
        <select name="service_type" required>
          <option value="">Select a service</option>
          <option value="Business Wi-Fi">Business Wi-Fi</option>
          <option value="Network setup">Network setup</option>
          <option value="Firewall setup">Firewall setup</option>
          <option value="Network segmentation / VLANs">Network segmentation / VLANs</option>
          <option value="Website / SEO">Website / SEO</option>
          <option value="Small business IT support">Small business IT support</option>
          <option value="Full technology cleanup">Full technology cleanup</option>
          <option value="General question">General question</option>
        </select>
      </label>

      <label class="contact-field contact-field-wide">
        <span>Project details</span>
        <textarea
          name="message"
          rows="6"
          placeholder="Tell us about your space, current setup, issue, deadline, or what you want improved."
          required
        ></textarea>
      </label>

      <label class="contact-field contact-field-wide">
        <span>Preferred timeline</span>
        <select name="timeline">
          <option value="">Select a timeline</option>
          <option value="ASAP">ASAP</option>
          <option value="This week">This week</option>
          <option value="This month">This month</option>
          <option value="Planning ahead">Planning ahead</option>
          <option value="Not sure yet">Not sure yet</option>
        </select>
      </label>

      <input
        class="contact-honeypot"
        type="text"
        name="_gotcha"
        tabindex="-1"
        autocomplete="off"
      />

      <div class="contact-form-footer">
        <p data-form-status aria-live="polite">
          Response usually begins with a quick review of your setup and project needs.
        </p>

        <button type="submit">
          Send Request
          <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M1 6h10M6 1l5 5-5 5" />
          </svg>
        </button>
      </div>
    </form>
  </div>
</div>

<script is:inline>
  function initOzonyContactForm() {
    const form = document.querySelector("[data-ozony-contact-form]");

    if (!form || form.dataset.bound === "true") return;

    form.dataset.bound = "true";

    const status = form.querySelector("[data-form-status]");
    const submitButton = form.querySelector('button[type="submit"]');
    const originalButtonText = submitButton ? submitButton.innerHTML : "";

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!submitButton || !status) return;

      submitButton.disabled = true;
      submitButton.innerHTML = "Sending...";
      status.textContent = "Sending your request...";

      try {
        const formData = new FormData(form);

        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json",
          },
        });

        if (response.ok) {
          form.reset();
          status.textContent =
            "Request sent. Ozony Tech will review your message and follow up soon.";
        } else {
          status.textContent =
            "Something went wrong sending the form. Please try again.";
        }
      } catch (error) {
        status.textContent =
          "Connection issue. Please try again or email contact@ozony.tech.";
      } finally {
        submitButton.disabled = false;
        submitButton.innerHTML = originalButtonText;
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initOzonyContactForm);
  document.addEventListener("astro:page-load", initOzonyContactForm);

  if (document.readyState !== "loading") {
    initOzonyContactForm();
  }
</script>

