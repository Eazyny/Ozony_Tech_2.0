<script>
  function initFooterClock() {
    const hourHand = document.querySelector("[data-hour-hand]");
    const minuteHand = document.querySelector("[data-minute-hand]");
    const secondHand = document.querySelector("[data-second-hand]");
    const digital = document.querySelector("[data-clock-digital]");
    const zone = document.querySelector("[data-clock-zone]");

    if (!hourHand || !minuteHand || !secondHand || !digital || !zone) return;

    function updateClock() {
      const now = new Date();

      const nyFormatter = new Intl.DateTimeFormat("en-US", {
        timeZone: "America/New_York",
        hour: "numeric",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
      });

      const parts = nyFormatter.formatToParts(now);

      const hour = Number(parts.find((p) => p.type === "hour")?.value || 0);
      const minute = Number(parts.find((p) => p.type === "minute")?.value || 0);
      const second = Number(parts.find((p) => p.type === "second")?.value || 0);
      const dayPeriod = parts.find((p) => p.type === "dayPeriod")?.value || "AM";

      const hourForRotation = hour % 12;

      const hourDeg = hourForRotation * 30 + minute * 0.5 + second * (0.5 / 60);
      const minuteDeg = minute * 6 + second * 0.1;
      const secondDeg = second * 6;

      hourHand.style.transform = `translateY(-50%) rotate(${hourDeg}deg)`;
      minuteHand.style.transform = `translateY(-50%) rotate(${minuteDeg}deg)`;
      secondHand.style.transform = `translateY(-50%) rotate(${secondDeg}deg)`;

      digital.textContent = `${String(hour).padStart(2, "0")}:${String(minute).padStart(2, "0")} ${dayPeriod.toUpperCase()}`;
      zone.textContent = "EST";
    }

    updateClock();
    clearInterval(window.__ozFooterClockTimer);
    window.__ozFooterClockTimer = setInterval(updateClock, 1000);
  }

  document.addEventListener("astro:page-load", initFooterClock);
  document.addEventListener("DOMContentLoaded", initFooterClock);

  if (document.readyState !== "loading") {
    initFooterClock();
  }
</script>

