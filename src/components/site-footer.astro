<script>
  function initFooterClock() {
    const nycTimeEl = document.querySelector<HTMLElement>("[data-nyc-time]");
    const nycZoneEl = document.querySelector<HTMLElement>("[data-nyc-zone]");
    const clientHeadingEl = document.querySelector<HTMLElement>(
      "[data-client-heading]",
    );
    const clientZoneEl =
      document.querySelector<HTMLElement>("[data-client-zone]");
    const clientPrimaryEl = document.querySelector<HTMLElement>(
      "[data-client-primary]",
    );
    const clientSecondaryEl = document.querySelector<HTMLElement>(
      "[data-client-secondary]",
    );

    if (
      !nycTimeEl ||
      !nycZoneEl ||
      !clientHeadingEl ||
      !clientZoneEl ||
      !clientPrimaryEl ||
      !clientSecondaryEl
    ) {
      return;
    }

    const nycTime = nycTimeEl!;
    const nycZone = nycZoneEl!;
    const clientHeading = clientHeadingEl!;
    const clientZone = clientZoneEl!;
    const clientPrimary = clientPrimaryEl!;
    const clientSecondary = clientSecondaryEl!;

    const ozWindow = window as Window & {
      __ozFooterClockTimer?: number;
    };

    function getTimeData(timeZone?: string, date = new Date()) {
      const formatter = new Intl.DateTimeFormat("en-US", {
        ...(timeZone ? { timeZone } : {}),
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
        timeZoneName: "short",
      });

      const parts = formatter.formatToParts(date);

      const hour = parts.find((part) => part.type === "hour")?.value || "12";
      const minute =
        parts.find((part) => part.type === "minute")?.value || "00";
      const second =
        parts.find((part) => part.type === "second")?.value || "00";
      const period =
        parts.find((part) => part.type === "dayPeriod")?.value || "AM";
      const zone =
        parts.find((part) => part.type === "timeZoneName")?.value || "LOCAL";

      return {
        time: `${hour}:${minute}.${second} ${period.toUpperCase()}`,
        zone,
      };
    }

    function getReadableLocation(timeZone: string) {
      if (!timeZone) return "LOCAL";

      const segments = timeZone.split("/");
      const lastSegment = segments[segments.length - 1] || "Local";

      return lastSegment.replace(/_/g, " ").toUpperCase();
    }

    function updateClock() {
      const now = new Date();
      const nyc = getTimeData("America/New_York", now);
      const localTimeZone =
        Intl.DateTimeFormat().resolvedOptions().timeZone || "";
      const local = getTimeData(undefined, now);
      const localLocation = getReadableLocation(localTimeZone);

      const sameTimeBase =
        nyc.time === local.time &&
        nyc.zone.toUpperCase() === local.zone.toUpperCase();

      nycTime.textContent = nyc.time;
      nycZone.textContent = nyc.zone.toUpperCase();

      if (sameTimeBase) {
        clientHeading.textContent = "CLIENT NODE";
        clientZone.textContent = "SYNC";
        clientPrimary.textContent = "SYNCED WITH HQ";
        clientPrimary.classList.add("is-status");
        clientSecondary.textContent = `SAME TIME BASE // ${nyc.zone.toUpperCase()}`;
      } else {
        clientHeading.textContent = `CLIENT NODE // ${localLocation}`;
        clientZone.textContent = local.zone.toUpperCase();
        clientPrimary.textContent = local.time;
        clientPrimary.classList.remove("is-status");
        clientSecondary.textContent = `${localLocation} // LOCAL TIME`;
      }
    }

    updateClock();

    if (typeof ozWindow.__ozFooterClockTimer !== "undefined") {
      window.clearInterval(ozWindow.__ozFooterClockTimer);
    }

    ozWindow.__ozFooterClockTimer = window.setInterval(updateClock, 1000);
  }

  document.addEventListener("astro:page-load", initFooterClock);
  document.addEventListener("DOMContentLoaded", initFooterClock);

  if (document.readyState !== "loading") {
    initFooterClock();
  }
</script>

